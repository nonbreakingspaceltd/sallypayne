---
import { getPost } from '../../../../data/posts';
import LayoutPost from '../../../../layouts/Post.astro';

export const prerender = false;

const { year, month, slug } = Astro.params;
// The post's canonical path encodes its publish date — getPost resolves the
// post matching this exact path, so duplicate slugs in other months don't clash
const post =
  slug && year && month
    ? await getPost(slug, year, month, Astro.site)
    : undefined;

if (!post) {
  return new Response(null, { status: 404 });
}

const { title, body, publishedDate, meta } = post;
---

<LayoutPost variant="post" title={title} meta={meta} publishedDate={publishedDate} body={body} />
