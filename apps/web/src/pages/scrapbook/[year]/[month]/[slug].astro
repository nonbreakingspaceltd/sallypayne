---
import { getPost } from '../../../../data/posts';
import LayoutPost from '../../../../layouts/Post.astro';

export const prerender = false;

const { year, month, slug } = Astro.params;
const post = slug ? await getPost(slug, Astro.site) : undefined;

// The post's canonical path encodes its publish date — reject mismatches
if (!post || post.path !== `/scrapbook/${year}/${month}/${slug}/`) {
  return new Response(null, { status: 404 });
}

const { title, body, publishedDate, meta } = post;
---

<LayoutPost variant="post" title={title} meta={meta} publishedDate={publishedDate} body={body} />
