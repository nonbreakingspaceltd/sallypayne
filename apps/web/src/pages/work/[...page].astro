---
import type { WorkProps } from '../../../types';
import Pagination from '../../components/Pagination/Pagination.vue';
import Showcase from '../../components/Showcase/Showcase.vue';
import { getSiteSettings } from '../../data/global';
import { parsePageParam } from '../../data/utils/pageParam';
import { getWorkPage } from '../../data/work';
import LayoutList from '../../layouts/List.astro';

export const prerender = false;

const pageNumber = parsePageParam(Astro.params.page);
const page = pageNumber ? await getWorkPage(pageNumber) : undefined;

if (!page) {
  return new Response(null, { status: 404 });
}

const siteSettings = await getSiteSettings();

let title = 'Work';
let metaTitle = `Work | ${siteSettings.title}`;
let metaDescription =
  'A selection of illustration, design and craft projects by Sally Payne.';
if (page.currentPage > 1) {
  const paginationTitle = `(Page ${page.currentPage})`;
  title = `${title} ${paginationTitle}`;
  metaTitle = `${metaTitle} ${paginationTitle}`;
  metaDescription = `${metaDescription} ${paginationTitle}`;
}

const meta = {
  title: metaTitle,
  description: metaDescription,
  og: {
    image: `${Astro.site}images/og/home.jpg`,
  },
};

const works = page.data.map((work: WorkProps) => {
  const { title, path, excerpt, image, galleryBackground } = work;
  // map to showcase item props
  return {
    key: path,
    title,
    href: path,
    excerpt,
    image,
    backgroundColor: galleryBackground,
  };
});
---

<LayoutList title={title} meta={meta} variant="work">
  <Showcase items={works} />
  <Pagination client:idle totalPage={page.lastPage} currentPage={page.currentPage} basePath="/work" />
</LayoutList>
