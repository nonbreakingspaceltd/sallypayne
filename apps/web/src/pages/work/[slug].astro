---
import { getWork } from '../../data/work';
import LayoutWork from '../../layouts/Work.astro';

export const prerender = false;

const { slug } = Astro.params;
const work = slug ? await getWork(slug) : undefined;

if (!work) {
  return new Response(null, { status: 404 });
}

const { title, logo, body, slides, galleryBackground, meta } = work;
---

<LayoutWork
  variant="work"
  title={title}
  logo={logo}
  meta={meta}
  body={body}
  slides={slides}
  galleryBackground={galleryBackground}
/>
