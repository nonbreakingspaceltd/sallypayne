{
  "name": "@sallypayne/web",
  "version": "0.0.0-semantically-released",
  "private": true,
  "type": "module",
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "astro:build": "astro build",
    "astro:dev": "astro dev --verbose",
    "astro:preview": "astro preview",
    "build": "pnpm astro:build",
    "dev": "pnpm astro:dev --verbose",
    "preview": "pnpm astro:preview",
    "serve": "pnpm build && npx serve --config ../serve.json dist",
    "start": "pnpm dev",
    "transform:css": "tsx scripts/optimizeCss.js",
    "transform:html": "tsx scripts/optimizeHtml.js",
    "types:check": "astro check && vue-tsc --noEmit -p tsconfig.vue.json"
  },
  "dependencies": {
    "@astrojs/netlify": "^8.0.0",
    "@astrojs/vue": "7.0.0",
    "@portabletext/vue": "1.0.14",
    "@sanity/asset-utils": "2.3.0",
    "@sanity/image-url": "2.1.1",
    "astro": "7.0.3",
    "axios": "1.18.1",
    "axios-cache-interceptor": "1.12.0",
    "classnames": "2.5.1",
    "cross-fetch": "4.1.0",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "focus-lock": "1.3.6",
    "modern-normalize": "3.0.1",
    "vue": "3.5.39",
    "vue-dragscroll": "4.0.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/ts-plugin": "1.10.9",
    "@portabletext/types": "4.0.2",
    "@types/fs-extra": "11.0.4",
    "@types/postcss-mixins": "9.0.6",
    "@types/postcss-pxtorem": "6.1.0",
    "astro-compress": "2.4.1",
    "autoprefixer": "10.5.2",
    "cssnano": "8.0.2",
    "fs-extra": "11.3.5",
    "glob": "13.0.6",
    "html-entities": "2.6.0",
    "htmlnano": "3.3.2",
    "postcss": "8.5.16",
    "postcss-at-rules-variables": "0.3.0",
    "postcss-custom-media": "12.0.1",
    "postcss-import": "16.1.1",
    "postcss-mixins": "12.1.2",
    "postcss-nested": "7.0.2",
    "postcss-pxtorem": "6.1.0",
    "postcss-sorting": "10.0.0",
    "purgecss": "8.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-environment": "1.1.3",
    "vite-svg-loader": "5.1.1",
    "vue-tsc": "3.3.5"
  }
